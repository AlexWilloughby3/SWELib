-- Section 1: Method Properties Tests
section MethodTests

-- Test 1.1: Safe methods are GET, HEAD, OPTIONS, TRACE
#eval decide (Method.GET.isSafe = true)
#eval decide (Method.HEAD.isSafe = true)
#eval decide (Method.OPTIONS.isSafe = true)
#eval decide (Method.TRACE.isSafe = true)
#eval decide (Method.POST.isSafe = false)
#eval decide (Method.PUT.isSafe = false)
#eval decide (Method.DELETE.isSafe = false)
#eval decide (Method.CONNECT.isSafe = false)

-- Test 1.2: Idempotent methods are GET, HEAD, PUT, DELETE, OPTIONS, TRACE
#eval decide (Method.GET.isIdempotent = true)
#eval decide (Method.HEAD.isIdempotent = true)
#eval decide (Method.PUT.isIdempotent = true)
#eval decide (Method.DELETE.isIdempotent = true)
#eval decide (Method.OPTIONS.isIdempotent = true)
#eval decide (Method.TRACE.isIdempotent = true)
#eval decide (Method.POST.isIdempotent = false)
#eval decide (Method.CONNECT.isIdempotent = false)

-- Test 1.3: Cacheable by default: only GET and HEAD
#eval decide (Method.GET.isCacheableByDefault = true)
#eval decide (Method.HEAD.isCacheableByDefault = true)
#eval decide (Method.POST.isCacheableByDefault = false)
#eval decide (Method.PUT.isCacheableByDefault = false)
#eval decide (Method.DELETE.isCacheableByDefault = false)
#eval decide (Method.CONNECT.isCacheableByDefault = false)
#eval decide (Method.OPTIONS.isCacheableByDefault = false)
#eval decide (Method.TRACE.isCacheableByDefault = false)

-- Test 1.4: Theorem: safe_implies_idempotent
-- Verify for each safe method that it is also idempotent
#eval decide (Method.GET.isSafe → Method.GET.isIdempotent)
#eval decide (Method.HEAD.isSafe → Method.HEAD.isIdempotent)
#eval decide (Method.OPTIONS.isSafe → Method.OPTIONS.isIdempotent)
#eval decide (Method.TRACE.isSafe → Method.TRACE.isIdempotent)

-- Test 1.5: Theorem: cacheableByDefault_implies_safe
-- Verify for each cacheable-by-default method that it is safe
#eval decide (Method.GET.isCacheableByDefault → Method.GET.isSafe)
#eval decide (Method.HEAD.isCacheableByDefault → Method.HEAD.isSafe)

-- Test 1.6: Request body expected
#eval decide (Method.POST.requestBodyExpected = true)
#eval decide (Method.PUT.requestBodyExpected = true)
#eval decide (Method.GET.requestBodyExpected = false)
#eval decide (Method.HEAD.requestBodyExpected = false)
#eval decide (Method.DELETE.requestBodyExpected = false)
#eval decide (Method.OPTIONS.requestBodyExpected = false)
#eval decide (Method.TRACE.requestBodyExpected = false)

-- Test 1.7: Extension methods
def customMethod : Method := Method.extension "PATCH"
#eval repr customMethod
#eval decide (customMethod.isSafe = false)
#eval decide (customMethod.isIdempotent = false)
#eval decide (customMethod.isCacheableByDefault = false)

-- Test 1.8: Method string representation
#eval toString Method.GET
#eval toString Method.POST
#eval toString (Method.extension "CUSTOM")

end MethodTests

-- Section 2: Status Code Tests
section StatusCodeTests

-- Test 2.1: Valid range 100-999
def validStatus100 : StatusCode := ⟨100, by decide⟩
def validStatus999 : StatusCode := ⟨999, by decide⟩
#eval repr validStatus100
#eval repr validStatus999

-- Test 2.2: Status classes
#eval decide (StatusCode.continue_.statusClass = some StatusClass.informational)
#eval decide (StatusCode.ok.statusClass = some StatusClass.successful)
#eval decide (StatusCode.movedPermanently.statusClass = some StatusClass.redirection)
#eval decide (StatusCode.badRequest.statusClass = some StatusClass.clientError)
#eval decide (StatusCode.internalServerError.statusClass = some StatusClass.serverError)

-- Test 2.3: Body constraints - 1xx, 204, 304 MUST NOT have body
#eval decide (StatusCode.continue_.mayHaveBody = false)
#eval decide (StatusCode.switchingProtocols.mayHaveBody = false)
#eval decide (StatusCode.noContent.mayHaveBody = false)
#eval decide (StatusCode.notModified.mayHaveBody = false)
#eval decide (StatusCode.ok.mayHaveBody = true)
#eval decide (StatusCode.created.mayHaveBody = true)

-- Test 2.4: Interim vs Final status
#eval decide (StatusCode.continue_.isInterim = true)
#eval decide (StatusCode.continue_.isFinal = false)
#eval decide (StatusCode.ok.isInterim = false)
#eval decide (StatusCode.ok.isFinal = true)

-- Test 2.5: Error status codes
#eval decide (StatusCode.badRequest.isError = true)
#eval decide (StatusCode.internalServerError.isError = true)
#eval decide (StatusCode.ok.isError = false)
#eval decide (StatusCode.movedPermanently.isError = false)

-- Test 2.6: Theorem: interim_no_body
-- All interim (1xx) responses should not have body
#eval decide (StatusCode.continue_.isInterim → ¬StatusCode.continue_.mayHaveBody)
#eval decide (StatusCode.switchingProtocols.isInterim → ¬StatusCode.switchingProtocols.mayHaveBody)

-- Test 2.7: Theorem: error_is_final
-- All error status codes are final responses
#eval decide (StatusCode.badRequest.isError → StatusCode.badRequest.isFinal)
#eval decide (StatusCode.internalServerError.isError → StatusCode.internalServerError.isFinal)

-- Test 2.8: Well-known status codes
#eval decide (StatusCode.ok.code = 200)
#eval decide (StatusCode.noContent.code = 204)
#eval decide (StatusCode.notModified.code = 304)
#eval decide (StatusCode.badRequest.code = 400)
#eval decide (StatusCode.notFound.code = 404)
#eval decide (StatusCode.methodNotAllowed.code = 405)
#eval decide (StatusCode.internalServerError.code = 500)

end StatusCodeTests

-- Section 3: Header Field Tests
section FieldTests

-- Test 3.1: Case-insensitive field name comparison
def hostLower : FieldName := ⟨"host"⟩
def hostUpper : FieldName := ⟨"HOST"⟩
def hostMixed : FieldName := ⟨"Host"⟩
#eval decide (hostLower == hostUpper)
#eval decide (hostUpper == hostMixed)
#eval decide (hostLower == hostMixed)

-- Test 3.2: Header list operations
def testHeaders : Headers := [
  { name := FieldName.host, value := "example.com" },
  { name := FieldName.contentType, value := "text/html" },
  { name := FieldName.accept, value := "text/html" },
  { name := FieldName.accept, value := "application/json" }
]

-- Test 3.3: get? - get first value
#eval testHeaders.get? FieldName.host
#eval testHeaders.get? FieldName.contentType
#eval testHeaders.get? FieldName.accept
#eval testHeaders.get? FieldName.contentLength

-- Test 3.4: getAll - get all values for a field
#eval testHeaders.getAll FieldName.accept
#eval testHeaders.getAll FieldName.host
#eval testHeaders.getAll FieldName.contentLength

-- Test 3.5: getCombined - combine all values with ", "
#eval testHeaders.getCombined FieldName.accept
#eval testHeaders.getCombined FieldName.host
#eval testHeaders.getCombined FieldName.contentLength

-- Test 3.6: contains - check if field exists
#eval decide (testHeaders.contains FieldName.host)
#eval decide (testHeaders.contains FieldName.accept)
#eval decide (testHeaders.contains FieldName.contentLength)

-- Test 3.7: add - add a field
def updatedHeaders := testHeaders.add FieldName.contentLength "42"
#eval updatedHeaders.get? FieldName.contentLength

-- Test 3.8: remove - remove all fields with name
def removedHeaders := testHeaders.remove FieldName.accept
#eval decide (removedHeaders.contains FieldName.accept = false)
#eval decide (removedHeaders.contains FieldName.host = true)

-- Test 3.9: Content-Length parsing
def headersWithContentLength : Headers := [
  { name := FieldName.contentLength, value := "123" }
]
def headersWithInvalidContentLength : Headers := [
  { name := FieldName.contentLength, value := "not-a-number" }
]
#eval headersWithContentLength.getContentLength
#eval headersWithInvalidContentLength.getContentLength

-- Test 3.10: Theorem: getAll_nil
#eval Headers.getAll [] FieldName.host

-- Test 3.11: Well-known field names
#eval repr FieldName.host
#eval repr FieldName.contentType
#eval repr FieldName.contentLength
#eval repr FieldName.etag
#eval repr FieldName.allow

end FieldTests

-- Section 4: Request Target Tests
section TargetTests

-- Test 4.1: Default ports for schemes
#eval SWELib.Networking.Http.defaultPort "http"
#eval SWELib.Networking.Http.defaultPort "https"
#eval SWELib.Networking.Http.defaultPort "ftp"

-- Test 4.2: Effective port resolution
def httpUri : Uri := {
  scheme := "http"
  authority := some { host := "example.com", port := none }
}
def httpsUri : Uri := {
  scheme := "https"
  authority := some { host := "example.com", port := none }
}
def httpUriWithPort : Uri := {
  scheme := "http"
  authority := some { host := "example.com", port := some 8080 }
}
-- Note: effectivePort is defined in Http.Target, not Uri
#eval SWELib.Networking.Http.Uri.effectivePort httpUri
#eval SWELib.Networking.Http.Uri.effectivePort httpsUri
#eval SWELib.Networking.Http.Uri.effectivePort httpUriWithPort

-- Test 4.3: Non-empty host validation
def uriWithHost : Uri := {
  scheme := "http"
  authority := some { host := "example.com", port := none }
}
def uriWithEmptyHost : Uri := {
  scheme := "http"
  authority := some { host := "", port := none }
}
def uriNoAuthority : Uri := {
  scheme := "http"
  authority := none
}
-- Note: hasNonEmptyHost is defined in Http.Target, not Uri
#eval decide (SWELib.Networking.Http.Uri.hasNonEmptyHost uriWithHost = true)
#eval decide (SWELib.Networking.Http.Uri.hasNonEmptyHost uriWithEmptyHost = false)
#eval decide (SWELib.Networking.Http.Uri.hasNonEmptyHost uriNoAuthority = false)

-- Test 4.4: Request target forms
def originFormTarget := RequestTarget.originForm "/path/to/resource" (some "q=test")
def absoluteFormTarget := RequestTarget.absoluteForm httpUri
def authorityFormTarget := RequestTarget.authorityForm "example.com" 443
def asteriskFormTarget := RequestTarget.asteriskForm
#eval repr originFormTarget
#eval repr absoluteFormTarget
#eval repr authorityFormTarget
#eval repr asteriskFormTarget

-- Test 4.5: Theorem: defaultPort_http
#eval decide (SWELib.Networking.Http.defaultPort "http" = some 80)

-- Test 4.6: Theorem: defaultPort_https
#eval decide (SWELib.Networking.Http.defaultPort "https" = some 443)

end TargetTests

-- Section 5: ETag Operations Tests
section ETagTests

-- Test 5.1: Strong vs weak ETags
def strongETag1 : ETag := { value := "abc123", weak := false }
def strongETag2 : ETag := { value := "abc123", weak := false }
def strongETag3 : ETag := { value := "def456", weak := false }
def weakETag1 : ETag := { value := "abc123", weak := true }
def weakETag2 : ETag := { value := "abc123", weak := true }

-- Test 5.2: Strong comparison
#eval decide (strongETag1.strongEq strongETag2 = true)
#eval decide (strongETag1.strongEq strongETag3 = false)
#eval decide (strongETag1.strongEq weakETag1 = false)
#eval decide (weakETag1.strongEq weakETag2 = false)

-- Test 5.3: Weak comparison
#eval decide (strongETag1.weakEq strongETag2 = true)
#eval decide (strongETag1.weakEq weakETag1 = true)
#eval decide (weakETag1.weakEq weakETag2 = true)
#eval decide (strongETag1.weakEq strongETag3 = false)

-- Test 5.4: Theorem: strong_implies_weak
#eval decide (strongETag1.strongEq strongETag2 → strongETag1.weakEq strongETag2)

-- Test 5.5: Theorem: weakEq_refl (reflexivity)
#eval decide (strongETag1.weakEq strongETag1 = true)
#eval decide (weakETag1.weakEq weakETag1 = true)

-- Test 5.6: Theorem: weakEq_symm (symmetry)
#eval decide ((strongETag1.weakEq weakETag1) = (weakETag1.weakEq strongETag1))

-- Test 5.7: String representation
#eval toString strongETag1
#eval toString weakETag1

end ETagTests

