-- Section 8: Contract Validation Tests
section ContractTests

-- Test 8.1: Request validity - Host header
def requestWithHost : Request := {
  method := Method.GET
  target := RequestTarget.originForm "/" none
  headers := [{ name := FieldName.host, value := "example.com" }]
}
def requestNoHost : Request := {
  method := Method.GET
  target := RequestTarget.originForm "/" none
  headers := []
}
#eval decide (requestWithHost.hasHost = true)
#eval decide (requestNoHost.hasHost = false)

-- Test 8.2: Request validity - TRACE no body
-- These tests verify the contract properties but can't directly test Props
-- We test the conditions that would make the Props true/false
def traceRequest : Request := {
  method := Method.TRACE
  target := RequestTarget.originForm "/" none
  body := none
}
def traceWithBody : Request := {
  method := Method.TRACE
  target := RequestTarget.originForm "/" none
  body := some ⟨#[1, 2, 3]⟩
}
#eval decide (traceRequest.method = Method.TRACE ∧ traceRequest.body = none)
#eval decide (traceWithBody.method = Method.TRACE ∧ traceWithBody.body ≠ none)

-- Test 8.3: Request validity - asterisk form only with OPTIONS
def optionsAsterisk : Request := {
  method := Method.OPTIONS
  target := RequestTarget.asteriskForm
}
def getAsterisk : Request := {
  method := Method.GET
  target := RequestTarget.asteriskForm
}
-- Testing individual conditions since RequestTarget lacks Decidable instance
#eval decide (match optionsAsterisk.target with
  | RequestTarget.asteriskForm => optionsAsterisk.method = Method.OPTIONS
  | _ => false)
#eval decide (match getAsterisk.target with
  | RequestTarget.asteriskForm => getAsterisk.method ≠ Method.OPTIONS
  | _ => false)

-- Test 8.4: Request validity - authority form only with CONNECT
def connectAuthority : Request := {
  method := Method.CONNECT
  target := RequestTarget.authorityForm "example.com" 443
}
#eval decide (connectAuthority.method = Method.CONNECT)
#eval match connectAuthority.target with
  | RequestTarget.authorityForm _ _ => true
  | _ => false

-- Test 8.5: Response validity - 1xx, 204, 304 no body
def response100 : Response := { status := StatusCode.continue_, body := none }
def response204 : Response := { status := StatusCode.noContent, body := none }
def response304 : Response := { status := StatusCode.notModified, body := none }
def response200 : Response := { status := StatusCode.ok, body := some ⟨#[]⟩ }

#eval decide (response100.status.mayHaveBody = false)
#eval decide (response204.status.mayHaveBody = false)
#eval decide (response304.status.mayHaveBody = false)
#eval decide (response200.status.mayHaveBody = true)

-- Test 8.6: Response validity - 405 must have Allow header
def response405WithAllow : Response := {
  status := StatusCode.methodNotAllowed
  headers := [{ name := FieldName.allow, value := "GET, HEAD, POST" }]
}
def response405NoAllow : Response := {
  status := StatusCode.methodNotAllowed
  headers := []
}
#eval decide (response405WithAllow.status.code = 405 ∧ response405WithAllow.headers.contains FieldName.allow)
#eval decide (response405NoAllow.status.code = 405 ∧ ¬response405NoAllow.headers.contains FieldName.allow)

-- Test 8.7: Content-Length validity
def responseWithValidLength : Response := {
  status := StatusCode.ok
  headers := [{ name := FieldName.contentLength, value := "5" }]
  body := some ⟨#[72, 101, 108, 108, 111]⟩  -- "Hello"
}
def responseWithInvalidLength : Response := {
  status := StatusCode.ok
  headers := [{ name := FieldName.contentLength, value := "10" }]
  body := some ⟨#[72, 101, 108, 108, 111]⟩  -- "Hello" (5 bytes, not 10)
}
#eval decide (responseWithValidLength.contentLength = some 5)
#eval decide (responseWithValidLength.body.map (·.size) = some 5)
#eval decide (responseWithInvalidLength.contentLength = some 10)
#eval decide (responseWithInvalidLength.body.map (·.size) = some 5)

end ContractTests

-- Section 9: Proxy Tests
section ProxyTests

-- Test 9.1: Proxy validation
def validProxy : SWELib.Networking.Proxy.Proxy := {
  type := .forward
  host := "proxy.example.com"
  port := 8080
  auth := none
  allowedPorts := none
}
def invalidProxy : SWELib.Networking.Proxy.Proxy := {
  type := .forward
  host := ""
  port := 8080
}
#eval decide (SWELib.Networking.Proxy.Proxy.isValid validProxy)
#eval decide (SWELib.Networking.Proxy.Proxy.isValid invalidProxy)

-- Test 9.2: Port restrictions
def proxyWithPortRestrictions : SWELib.Networking.Proxy.Proxy := {
  type := .tunnel
  host := "proxy.example.com"
  port := 8080
  allowedPorts := some [80, 443, 8080]
}
#eval decide (SWELib.Networking.Proxy.Proxy.allowsPort proxyWithPortRestrictions 443)
#eval decide (SWELib.Networking.Proxy.Proxy.allowsPort proxyWithPortRestrictions 22)
#eval decide (SWELib.Networking.Proxy.Proxy.allowsPort validProxy 22)  -- No restrictions

-- Test 9.3: Via header addition
def proxyRequest : Request := {
  method := Method.GET
  target := RequestTarget.originForm "/" none
  headers := [{ name := FieldName.host, value := "example.com" }]
}
def proxiedRequest := SWELib.Networking.Proxy.addViaHeader proxyRequest Version.http11 "proxy.example.com"
#eval proxiedRequest.headers.get? ⟨"Via"⟩

-- Test 9.4: Proxy authentication
def proxyWithAuth : SWELib.Networking.Proxy.Proxy := {
  type := .forward
  host := "proxy.example.com"
  port := 8080
  auth := some { username := "user", password := "pass" }
}
#eval decide (SWELib.Networking.Proxy.Proxy.requiresAuth proxyWithAuth)
#eval decide (SWELib.Networking.Proxy.Proxy.requiresAuth validProxy)

end ProxyTests

